{
  "manifest_version": 3,
  "name": "CRM New Message Notifier",
  "version": "1.0",
  "description": "Notifies you when a new customer message arrives in your CRM",
  "permissions": [
    "notifications",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://dev.cs.bpakr.wecar.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://dev.cs.bpakr.wecar.ai/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "CRM Notifier"
  }
}
